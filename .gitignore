# Python cache and bytecode
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/

# Build and packaging artifacts
build/
*.egg-info/
.eggs/
*.egg

# PyInstaller artifacts
*.spec

